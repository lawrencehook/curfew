{
  "manifest_version": 3,
  "name": "Curb",
  "version": "0.3.1",
  "description": "Set time limits for distracting websites",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background/main.js"
  },
  "action": {
    "default_popup": "popup/main.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Curb"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [{
    "resources": ["blocked/main.html"],
    "matches": ["<all_urls>"]
  }]
}
