{
  "manifest_version": 3,
  "name": "Curb",
  "version": "0.1.0",
  "description": "Set daily time limits for distracting websites",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background/main.js"
  },
  "action": {
    "default_popup": "popup/main.html",
    "default_icon": "icons/icon.svg",
    "default_title": "Curb"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "web_accessible_resources": [{
    "resources": ["blocked/main.html"],
    "matches": ["<all_urls>"]
  }]
}
