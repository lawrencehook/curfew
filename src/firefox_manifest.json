{
  "manifest_version": 2,
  "name": "Curb",
  "version": "0.3.1",
  "description": "Set time limits for distracting websites",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background/main.js"]
  },
  "browser_action": {
    "default_popup": "popup/main.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Curb"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    "blocked/main.html"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "curb@lawrencehook",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
