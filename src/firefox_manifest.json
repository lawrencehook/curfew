{
  "manifest_version": 2,
  "name": "Curb",
  "version": "0.1.0",
  "description": "Set daily time limits for distracting websites",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background/main.js"]
  },
  "browser_action": {
    "default_popup": "popup/main.html",
    "default_icon": "icons/icon.svg",
    "default_title": "Curb"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "web_accessible_resources": [
    "blocked/main.html"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "curb@lawrencehook",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
