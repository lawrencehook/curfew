# Server
# Local dev: 3000.  Production (behind nginx /curb/): 3006.
PORT=3000
BASE_URL=http://localhost:3000

# JWT (must be at least 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-secret-here-min-32-chars

# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
EMAIL_FROM=curb_noreply@lawrencehook.com

# SQLite data dir (default: ./data)
# In production, point this somewhere outside the git checkout so deploys
# (which run `git checkout -- .`) don't clobber storage.db.
# DATA_DIR=./data
